{
  "primary": {
    "provider": "openrouter",
    "baseUrl": "https://openrouter.ai/api/v1",
    "model": "openrouter/free"
  },
  "fallback": {
    "provider": "nvidia",
    "baseUrl": "https://integrate.api.nvidia.com/v1",
    "model": ""
  },
  "policy": {
    "retry429": 1,
    "fallbackOnStatus": [
      429,
      500,
      502,
      503,
      504
    ],
    "requireJsonOutput": true
  }
}